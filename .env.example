# FireFeed Root Environment Configuration
# Copy to .env and replace example values with actual ones

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=firefeed
DB_USER=firefeed_api
DB_PASSWORD=firefeed_password_example

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=firefeed_redis_pass_example
REDIS_DB=0

# JWT Secret Key - REQUIRED for all services
# Generate with: openssl rand -hex 32
FIREFEED_JWT_SECRET_KEY=your-secret-key-here

# JWT Issuer (optional, defaults to "firefeed-api")
FIREFEED_JWT_ISSUER=firefeed-api

# Service tokens (generate with tools/generate_service_token.py)
# RSS Parser
RSS_PARSER_SERVICE_ID=rss-parser
RSS_PARSER_SERVICE_API_TOKEN=your_rss_parser_token_here

# Telegram Bot
TELEGRAM_BOT_SERVICE_ID=telegram-bot
TELEGRAM_BOT_SERVICE_API_TOKEN=your_telegram_bot_token_here
